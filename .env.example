# Collaborative / shared editing backend (Supabase).
# Copy to ".env.local" for local dev, and set the same two as GitHub repo
# Variables (Settings → Secrets and variables → Actions → Variables) for the
# deployed site. Leaving these unset keeps the app in local-only mode.
#
# Both values come from your Supabase project: Settings → API.
# The anon key is a PUBLIC client key (it ships in the browser bundle); access
# is controlled by the row-level-security policies in supabase/schema.sql.

VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY
